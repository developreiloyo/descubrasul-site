# ─── Django ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Produção: adicionar descubrasul.com,www.descubrasul.com
# USE_X_FORWARDED_HOST=True  ← obrigatório atrás do Traefik/EasyPanel
# ─── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_DB=descubrasul
POSTGRES_USER=descubrasul_user
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://descubrasul_user:change-me-strong-password@db:5432/descubrasul
# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# ─── APIs externas ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GOOGLE_MAPS_API_KEY=
# ─── Storage Cloudflare R2 (S3-compatible, egress gratuito) ──────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=descubrasul-imagens
R2_ENDPOINT_URL=
R2_PUBLIC_DOMAIN=
# ─── Next.js ──────────────────────────────────────────────────────────
# URL interna (SSR dentro de Docker — container fala com container)
API_URL_INTERNAL=http://backend:8000/api
# URL pública (browser do visitante — prefixo NEXT_PUBLIC_ = visível no browser)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GA4_ID=
FRONTEND_URL=http://localhost:3000
# ─── E-mail (reset de senha) ──────────────────────────────────────────
# Dev: imprime no terminal (sem envio real)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Prod: usar Resend (resend.com — free tier: 3000 emails/mês)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx
